{
  "compilerOptions": {
    "target": "ES2016",
    "module": "ES2015",
    "sourceMap": true,
    "outDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2015", "DOM"]
  },
  "include": ["*.ts"]
}